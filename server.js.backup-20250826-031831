// Gmail API setup
const SCOPES = ['https://www.googleapis.com/auth/gmail.readonly'];
const TOKEN_PATH = 'token.json';
const CREDENTIALS_PATH = 'gcp-oauth.keys.json';

let gmail = null;

// Initialize Gmail API
async function initializeGmailAPI() {
  try {
    // Load client secrets from a local file
    const credentials = await fs.readFile(CREDENTIALS_PATH);
    const { client_secret, client_id, redirect_uris } = JSON.parse(credentials).web || JSON.parse(credentials).installed;
    const oAuth2Client = new google.auth.OAuth2(client_id, client_secret, redirect_uris[0]);

    // Check if we have previously stored a token
    try {
      const token = await fs.readFile(TOKEN_PATH);
      oAuth2Client.setCredentials(JSON.parse(token));
      gmail = google.gmail({ version: 'v1', auth: oAuth2Client });
      console.log('Gmail API initialized successfully');
      return true;
    } catch (error) {
      console.log('No valid token found. Please run authentication flow.');
      return false;
    }
  } catch (error) {
    console.error('Error loading credentials:', error.message);
    return false;
  }
}

// Get authorization URL
async function getAuthUrl() {
  try {
    const credentialsData = await fs.readFile(CREDENTIALS_PATH);
    const credentials = JSON.parse(credentialsData);
    const { client_secret, client_id, redirect_uris } = credentials.web || credentials.installed;
    const oAuth2Client = new google.auth.OAuth2(client_id, client_secret, redirect_uris[0]);
    
    const authUrl = oAuth2Client.generateAuthUrl({
      access_type: 'offline',
      scope: SCOPES,
    });
    return authUrl;
  } catch (error) {
    throw new Error('Credentials file not found. Please set up credentials.json first.');
  }
}

// Exchange authorization code for tokens
async function getAccessToken(code) {
  try {
    const credentialsData = await fs.readFile(CREDENTIALS_PATH);
    const credentials = JSON.parse(credentialsData);
    const { client_secret, client_id, redirect_uris } = credentials.web || credentials.installed;
    const oAuth2Client = new google.auth.OAuth2(client_id, client_secret, redirect_uris[0]);
    
    const { tokens } = await oAuth2Client.getToken(code);
    oAuth2Client.setCredentials(tokens);
    
    // Store the token to disk for later program executions
    await fs.writeFile(TOKEN_PATH, JSON.stringify(tokens));
    console.log('Token stored to', TOKEN_PATH);
    
    gmail = google.gmail({ version: 'v1', auth: oAuth2Client });
    return tokens;
  } catch (error) {
    throw new Error('Failed to exchange authorization code: ' + error.message);
  }
}

// Simple email categorization logic
function categorizeEmail(subject, body, from) {
  const subjectLower = subject.toLowerCase();
  const bodyLower = body.toLowerCase();
  const fromLower = from.toLowerCase();

  if (subjectLower.includes('meeting') || subjectLower.includes('invitation') || subjectLower.includes('calendar')) {
    return 'Meeting & Scheduling';
  }
  if (subjectLower.includes('phd') || subjectLower.includes('academic') || subjectLower.includes('university') || 
      subjectLower.includes('research') || fromLower.includes('columbia.edu')) {
    return 'Academic Affairs';
  }
  if (subjectLower.includes('payment') || subjectLower.includes('invoice') || subjectLower.includes('financial') ||
      subjectLower.includes('money') || subjectLower.includes('contest')) {
    return 'Financial & Reimbursements';
  }
  return 'General & Administrative';
}

