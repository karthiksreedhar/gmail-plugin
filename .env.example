# Environment Variables for Gmail Plugin

# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Connection (required for production)
MONGODB_URI=your_mongodb_connection_string_here

# Current User Email (default user)
CURRENT_USER_EMAIL=ks4190@columbia.edu

# Sending Email (can be different from current user if using aliases)
SENDING_EMAIL=ks4190@columbia.edu

# Server Configuration
PORT=3000
BASE_URL=http://localhost:3000

# Vercel Cron Security (optional but recommended)
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# Node Environment
NODE_ENV=development
