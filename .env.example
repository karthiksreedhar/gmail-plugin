# Server
PORT=3000

# OpenAI (required for AI features: generation, classifiers, summaries)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Current user context (defaults can be overridden at runtime via API)
CURRENT_USER_EMAIL=ks4190@columbia.edu
SENDING_EMAIL=ks4190@columbia.edu

# Storage selection
# Set USE_DB=true and DB_TYPE=mongo to enable Mongo token storage (recommended for production).
# When false, the app uses only local JSON files under ./data/<user@domain>/
USE_DB=true
DB_TYPE=mongo

# MongoDB (required when DB_TYPE=mongo)
# Example:
# MONGO_URI="mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority"
MONGO_URI=
MONGO_DB_NAME=gmail-plugin

# Google OAuth credentials are provided via file, not env:
# Preferred (per-user): data/<user@domain>/gcp-oauth.keys.json
# Fallback (global):    ./gcp-oauth.keys.json
# OAuth redirect must include: http://localhost:3000/oauth2callback
